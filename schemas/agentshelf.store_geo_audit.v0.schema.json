{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wureny/AgentShelf/schemas/agentshelf.store_geo_audit.v0.schema.json",
  "title": "AgentShelf Store GEO Audit v0",
  "type": "object",
  "required": [
    "contract",
    "generatedAt",
    "rootPath",
    "sourceType",
    "storeProfile",
    "pages",
    "pageGroups",
    "storeScore",
    "pageScores",
    "categoryScores",
    "missingPageTypes",
    "crossPageIssues",
    "issues",
    "topActions",
    "taskSuggestions",
    "reportMarkdown",
    "limitations"
  ],
  "properties": {
    "contract": { "const": "agentshelf.store_geo_audit.v0" },
    "generatedAt": { "type": "string" },
    "rootPath": { "type": "string" },
    "sourceType": { "type": "string" },
    "storeProfile": { "type": "object" },
    "pages": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
    "pageGroups": { "type": "object" },
    "storeScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "pageScores": { "type": "object" },
    "categoryScores": { "type": "object" },
    "missingPageTypes": { "type": "array", "items": { "type": "string" } },
    "crossPageIssues": { "type": "array", "items": { "type": "object" } },
    "issues": { "type": "array", "items": { "type": "object" } },
    "opportunities": { "type": "array", "items": { "type": "object" } },
    "topActions": { "type": "array", "items": { "type": "object" } },
    "taskSuggestions": { "type": "array", "items": { "type": "object" } },
    "reportMarkdown": { "type": "string" },
    "reportHtml": { "type": "string" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "rawMetadata": { "type": "object" }
  },
  "additionalProperties": true
}
